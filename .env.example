TRIX_BIND_ADDR=0.0.0.0:8080
TRIX_PUBLIC_BASE_URL=http://localhost:8080
TRIX_DATABASE_URL=postgres://trix:trix@localhost:5432/trix
TRIX_BLOB_ROOT=./blobs
TRIX_BLOB_MAX_UPLOAD_BYTES=26214400
TRIX_LOG=info,trix_server=debug
TRIX_JWT_SIGNING_KEY=dev-local-jwt-secret-change-me
TRIX_ADMIN_USERNAME=ops
TRIX_ADMIN_PASSWORD=dev-admin-secret-change-me
TRIX_ADMIN_JWT_SIGNING_KEY=dev-admin-jwt-secret-change-me
TRIX_ADMIN_SESSION_TTL_SECONDS=900
TRIX_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRIX_RATE_LIMIT_WINDOW_SECONDS=60
TRIX_RATE_LIMIT_AUTH_CHALLENGE_LIMIT=200
TRIX_RATE_LIMIT_AUTH_SESSION_LIMIT=200
TRIX_RATE_LIMIT_LINK_INTENTS_LIMIT=30
TRIX_RATE_LIMIT_DIRECTORY_LIMIT=120
TRIX_RATE_LIMIT_BLOB_UPLOAD_LIMIT=30
TRIX_CLEANUP_INTERVAL_SECONDS=300
TRIX_AUTH_CHALLENGE_RETENTION_SECONDS=3600
TRIX_LINK_INTENT_RETENTION_SECONDS=86400
TRIX_TRANSFER_BUNDLE_RETENTION_SECONDS=86400
TRIX_HISTORY_SYNC_RETENTION_SECONDS=604800
TRIX_PENDING_BLOB_RETENTION_SECONDS=86400
TRIX_SHUTDOWN_GRACE_PERIOD_SECONDS=15

# Opt-in aggregated debug metrics ingestion (/v0/accounts/me/debug/metrics and admin views).
# Leave unset or false in production unless you intend to collect technical counters/latency samples.
# TRIX_DEBUG_METRICS_ENABLED=1

# Optional APNs background push delivery for iOS/macOS clients.
# Configure all four values together to enable safe inbox wake-up pushes.
# TRIX_APNS_TEAM_ID=
# TRIX_APNS_KEY_ID=
# TRIX_APNS_TOPIC=com.softgrid.trixapp
# TRIX_APNS_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_ABC123XYZ.p8
# TRIX_APNS_PRIVATE_KEY_PEM=
