TRIX_RATE_LIMIT_LINK_INTENTS_LIMIT=30
TRIX_RATE_LIMIT_DIRECTORY_LIMIT=120
TRIX_RATE_LIMIT_BLOB_UPLOAD_LIMIT=30
TRIX_CLEANUP_INTERVAL_SECONDS=300
TRIX_AUTH_CHALLENGE_RETENTION_SECONDS=3600
TRIX_LINK_INTENT_RETENTION_SECONDS=86400
TRIX_TRANSFER_BUNDLE_RETENTION_SECONDS=86400
TRIX_HISTORY_SYNC_RETENTION_SECONDS=604800
