# Copy to .env only for local deployment overrides.
# Do not put passwords, registration tokens, private keys, or account secrets here.

# ejabberd is the product-fit default for the centralized control-plane path.
TRIX_XMPP_EJABBERD_IMAGE=ghcr.io/processone/ejabberd:latest

# Keep localhost bindings until TLS, DNS, firewall rules, and account bootstrap
# have been reviewed for the target host.
TRIX_XMPP_C2S_BIND=127.0.0.1
TRIX_XMPP_HTTP_BIND=127.0.0.1
# Optional local host-port overrides for parallel smoke projects.
# TRIX_XMPP_C2S_PORT=5222
# TRIX_XMPP_HTTP_PORT=5280

# Prosody is kept only as a lightweight shell-managed fallback/spike profile.
TRIX_XMPP_IMAGE=docker.io/prosody/prosody:latest
TRIX_XMPP_PROSODY_C2S_BIND=127.0.0.1
TRIX_XMPP_PROSODY_HTTP_BIND=127.0.0.1
# TRIX_XMPP_PROSODY_C2S_PORT=5222
# TRIX_XMPP_PROSODY_HTTP_PORT=5280

# Optional APNs sender and XEP-0357 component for the XMPP pivot. Keep these on
# the private Docker network; do not expose the component port publicly. The
# gateway refuses empty, placeholder, and checked-in dev-default secrets.
# TRIX_XMPP_PUSH_COMPONENT_SECRET=
# TRIX_XMPP_COMPONENT_JID=push.trix.selfhost.ru
# TRIX_PUSH_GATEWAY_BUILD_CONTEXT=../..
# TRIX_PUSH_GATEWAY_DOCKERFILE=Dockerfile
# TRIX_PUSH_BIND=127.0.0.1
# TRIX_PUSH_PORT=8090
# TRIX_PUSH_BIND_ADDR=127.0.0.1:8090
# TRIX_PUSH_LOG=info,trix_push_gateway=debug,trix_push=debug
# TRIX_PUSH_GATEWAY_TOKEN=
# TRIX_PUSH_STORE_PATH=/var/lib/trix-push-gateway/registrations.json
# TRIX_APNS_KEY_DIR=./certs/apns
# TRIX_APNS_TEAM_ID=
# TRIX_APNS_KEY_ID=
# TRIX_APNS_TOPIC=com.softgrid.trixapp
# TRIX_APNS_PRIVATE_KEY_PATH=/run/secrets/apns/AuthKey_ABC123XYZ.p8
# TRIX_APNS_PRIVATE_KEY_PEM=

# Optional invite-registration wrapper. Keep the operator token secret and expose
# the app-facing endpoint only through private TLS/reverse-proxy policy.
# TRIX_INVITE_BIND=127.0.0.1
# TRIX_INVITE_PORT=8091
# TRIX_INVITE_STORE_PATH=/var/lib/trix-xmpp/invites.json
# TRIX_INVITE_OPERATOR_TOKEN=
# TRIX_INVITE_DEFAULT_TTL_SECONDS=604800
# Non-secret fixed-window rate-limit tuning for the invite wrapper.
# TRIX_INVITE_RATE_WINDOW_SECONDS=60
# TRIX_INVITE_RATE_LIMIT_DEFAULT=60
# TRIX_INVITE_RATE_LIMIT_HEALTH=120
# TRIX_INVITE_RATE_LIMIT_OPERATOR_INVITES=20
# TRIX_INVITE_RATE_LIMIT_ACCOUNT_INVITES=20
# TRIX_INVITE_RATE_LIMIT_PASSWORD_CHANGE=10
# TRIX_INVITE_RATE_LIMIT_REDEEM=12
# TRIX_INVITE_RATE_LIMIT_STICKER_PACK=30
# TRIX_INVITE_RATE_LIMIT_STICKER_FILE=60

# Local operator script anti-loop counters. Keep the state dir private.
# TRIX_XMPP_OPERATOR_RATE_STATE_DIR=/run/trix-xmpp/operator-rate
# TRIX_XMPP_OPERATOR_RATE_WINDOW_SECONDS=60
# TRIX_XMPP_OPERATOR_RATE_LIMIT_DEFAULT=30
# TRIX_XMPP_OPERATOR_RATE_LIMIT_PROVISION_USER=10
