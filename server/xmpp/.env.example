# Copy to .env only for local deployment overrides.
# Do not put passwords, registration tokens, private keys, or account secrets here.

# ejabberd is the product-fit default for the centralized control-plane path.
TRIX_XMPP_EJABBERD_IMAGE=ghcr.io/processone/ejabberd:latest

# Keep localhost bindings until TLS, DNS, firewall rules, and account bootstrap
# have been reviewed for the target host.
TRIX_XMPP_C2S_BIND=127.0.0.1
TRIX_XMPP_HTTP_BIND=127.0.0.1

# Prosody is kept only as a lightweight shell-managed fallback/spike profile.
TRIX_XMPP_IMAGE=docker.io/prosody/prosody:latest
TRIX_XMPP_PROSODY_C2S_BIND=127.0.0.1
TRIX_XMPP_PROSODY_HTTP_BIND=127.0.0.1
