# Copy to server/xmpp/livekit.yaml and replace keys with deployment-local values.
# Do not commit the real file.

port: 7880
bind_addresses:
  - 0.0.0.0

rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 50100
  # For direct public UDP candidates on a cloud host, keep use_external_ip true.
  # If external coturn runs in Docker on the same host and relay-only clients must
  # reach LiveKit through coturn, set this false in the uncommitted live config
  # and add node_ip=<livekit-container-ip>. Pair that with coturn
  # external-ip=<public-ip>/<coturn-container-ip> and a narrow
  # allowed-peer-ip=<livekit-container-ip>.
  use_external_ip: true
  # node_ip=<livekit-container-ip>

turn:
  enabled: false

keys:
  livekit-api-key-change-me: livekit-api-secret-change-me
